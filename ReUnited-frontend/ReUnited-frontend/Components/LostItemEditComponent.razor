<div class="field">
  <label class="label">Item Description</label>
  <div class="control">
    <InputText class="input" @bind-Value="EditLostItem.ItemDescription"/>
  </div>
</div>

<div class="field">
  <label class="label">City</label>
  <div class="control">
    <InputText class="input" @bind-Value="EditLostItem.City"/>
    <span class="icon is-small is-left">
      <i class="fas fa-envelope"></i>
    </span>
    <span class="icon is-small is-right">
      <i class="fas fa-exclamation-triangle"></i>
    </span>
  </div>
  @* <p class="help is-danger">This email is invalid</p> *@
</div>

<div class="field">
    <label class="label">Post Code</label>
    <div class="control">
        <InputText class="input" @bind-Value="EditLostItem.Postcode" />
        <span class="icon is-small is-left">
            <i class="fas fa-envelope"></i>
        </span>
        <span class="icon is-small is-right">
            <i class="fas fa-exclamation-triangle"></i>
        </span>
    </div>
    @* <p class="help is-danger">This email is invalid</p> *@
</div>

<div class="field">
    <label class="label">Category</label>
    <div class="control">
        <div class="select">
            <select>
                <option>Select Category</option>
                <option>Electronics</option>
                <option>Keys</option>
            </select>
        </div>
    </div>
</div>

<div class="field">
    <label class="label">Additional Information</label>
    <div class="control">
        <InputTextArea class="textarea" @bind-Value="EditLostItem.AdditionalInformation" />
    </div>
</div>

<div class="field">
    <label class="label">Post Code</label>
    <div class="control">
        <InputText class="input" @bind-Value="EditLostItem.PhoneNumber" />
        <span class="icon is-small is-left">
            <i class="fas fa-envelope"></i>
        </span>
        <span class="icon is-small is-right">
            <i class="fas fa-exclamation-triangle"></i>
        </span>
    </div>
    @* <p class="help is-danger">This email is invalid</p> *@
</div>


<div class="field is-grouped mb-5">
  <div class="control">
    <button class="button is-link">Submit</button>
  </div>
  <div class="control">
    <button class="button is-link is-light">Cancel</button>
  </div>
</div>




@code {
@using ReUnited_frontend.DataModels
@rendermode InteractiveServer

	[Parameter]
	public LostItem EditLostItem { get; set; } = new();

	[Parameter]
	public LostItem SuccessMessage { get; set; } = new();

	[Parameter]
	public EventCallback<LostItem> OnSave { get; set; }

	private async Task SaveItem()
	{
		await OnSave.InvokeAsync(EditLostItem);
	}

}
