@page "/lostitems/add"
@using ReUnited_frontend.DataModels


@if (LostItem == null)
{
    <div>
        <h3>Cannot add lost item</h3>
        <p>@errorMessage</p>
    </div>
}
else
{
    <div>
        <LostItemAddComponent LostItem="@LostItem" OnSave="SaveLostItem"/>
    </div>
}


@code {
    public LostItem? LostItem { get; set; }

    [Parameter]
    public int Id { get; set; }

    public HttpClient Client = new HttpClient();
    public bool isLoading = true;
    private string? errorMessage = String.Empty;


    private async Task SaveLostItem()
    {
        try
        {
            var response = await Client.PostAsJsonAsync<LostItem>($"http://localhost:5265/api/lostitems", LostItem);

            if (response != null)
            {
                response.EnsureSuccessStatusCode();
            }

            isLoading = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            errorMessage = $"An error occurred: {ex.Message}";

        }
    }

}
