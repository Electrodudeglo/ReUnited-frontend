@using System.Net.Http.Headers;
@using ReUnitedfrontend.DataModels;


@page "/login"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav


<input @bind="Username" placeholder="Username" />
<input @bind="Password" type="password" placeholder="Password" />
<button @onclick="LoginAsync">Login</button>

<div>
    @if (User.Authenticated)
    {
        <p>
            user is authenticated
        </p>
    }
    else
    {
        <p>
            user is not authenticated
        </p>
    }
    <br />
</div>

<div>
    <p>@LoginStatus</p>
</div>


@code {
    public string token { get; set; } = "";
    public string LoginStatus { get; set; } = "";

    public string Username { get; set; } = "";
    public string Password { get; set; } = "";

    private async Task LoginAsync()
    {

        LoginPayload loginPayload = new();
        loginPayload.Username = Username;
        loginPayload.Password = Password;

        var response = await Http.PostAsJsonAsync("api/auth/login", loginPayload);

        if (!response.IsSuccessStatusCode)
        {
            LoginStatus = "Login error";
            return;
        }

        token = await response.Content.ReadAsStringAsync();
        token = token.Trim('"');

        if (string.IsNullOrWhiteSpace(token))
        {
            LoginStatus = "Login succeeded but token was empty.";
            return;
        }

        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

        User.Token = token;
        User.Authenticated = true;

        Nav.NavigateTo("/");
    }
}