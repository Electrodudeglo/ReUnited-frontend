@using ReUnited_frontend.DataModels
@page "/lostitems/{Id:int}"

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh; text-align: center; padding: 2rem;">
    <h3 style="margin-bottom: 1.5rem;">Lost Item Details</h3>
    @if (LostItem == null)
    {
        <div>
            <h3>Cannot load lost items</h3>
            <p>@errorMessage</p>
        </div>
    }
    else
    {
        <div>
            <LostItemSummary LostItem="@LostItem" />
        </div>
    }
</div>

@code {
    [Parameter]
    public LostItem? LostItem { get; set; }
    [Parameter]
    public int Id { get; set; }
    public HttpClient Client = new HttpClient();
    public bool isLoading = true;
    private string? errorMessage = String.Empty;
    protected override async Task OnInitializedAsync()
    {
        try
        {
            LostItem = await Client.GetFromJsonAsync<LostItem>($"http://localhost:5265/api/lostitems/{Id}");
            isLoading = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            errorMessage = $"An error occurred: {ex.Message}";
        }
    }
}