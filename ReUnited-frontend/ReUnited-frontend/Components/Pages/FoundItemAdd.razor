@page "/founditems/add"
@rendermode InteractiveServer
@using ReUnited_frontend.DataModels
@inject HttpClient Http


@if (!User.Authenticated)
{
    <div class="notification is-warning">
        Please log in before submitting a found item.
    </div>
}
else if (FoundItem == null)
{
    <div>
        <h3>Cannot add found item</h3>
        <p>@errorMessage</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="notification is-danger">
        <p>@errorMessage</p>
    </div>
}
else
{
    <div class="fixed-grid has-3-cols">
        <div class="grid">
            <div class="cell is-col-start-2">
                <FoundItemAddComponent FoundItem="@FoundItem" OnSave="SaveFoundItem"
                                       SuccessMessage="SuccessItem" />
            </div>

        </div>
    </div>
}


@code {
    private FoundItem? FoundItem { get; set; } = new();

    [Parameter]
    public int Id { get; set; }

    public bool isLoading = true;
    private string? errorMessage;
    public bool SuccessItem { get; set; }


    private async Task SaveFoundItem((FoundItem Item, IBrowserFile? File) data)
    {
        try
        {
            using var content =
                        new MultipartFormDataContent();

            content.Add(
                new StringContent(data.Item.City),
                "City");

            content.Add(
                new StringContent(data.Item.Postcode),
                "Postcode");

            content.Add(
                new StringContent(
                    data.Item.DateFound.ToString("yyyy-MM-dd")),
                "DateFound");

            content.Add(
                new StringContent(
                    data.Item.Email ?? string.Empty),
                "Email");

            content.Add(
                new StringContent(
                    data.Item.PhoneNumber ?? string.Empty),
                "PhoneNumber");

            content.Add(
                new StringContent(
                    data.Item.Category),
                "Category");

            content.Add(
                new StringContent(
                    data.Item.ItemDescription),
                "ItemDescription");

            content.Add(
                new StringContent(
                    data.Item.AdditionalInformation),
                "AdditionalInformation");

            if (data.File is not null)
            {

                var stream =
                    data.File.OpenReadStream(10 * 1024 * 1024);

                var fileContent =
                    new StreamContent(stream);

                fileContent.Headers.ContentType =
                    new System.Net.Http.Headers
                        .MediaTypeHeaderValue(
                            data.File.ContentType);

                content.Add(
                    fileContent,
                    "Image",
                    data.File.Name);
            }

            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue(
                    "Bearer",
                    User.Token);

            var response =
        await Http.PostAsync(
            "http://localhost:5265/api/founditems",
            content);

            if (response.IsSuccessStatusCode)
            {
                SuccessItem = true;
            }
            else
            {
                var responseBody =
    await response.Content.ReadAsStringAsync();

                errorMessage =
                    $"Status: {(int)response.StatusCode} " +
                    $"{response.StatusCode}\n\n" +
                    responseBody;

                // errorMessage = "Failed to update item.";
            }

            isLoading = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            errorMessage = $"An error occurred: {ex.Message}";

        }
    }

}
