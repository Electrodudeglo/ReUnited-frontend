@using ReUnited_frontend.DataModels

<h3 class="title is-4">Lost Items</h3>

<div class="table-container">
    <table class="table is-striped is-hoverable is-fullwidth is-bordered">

        <thead>
            <tr>
                <th>Item</th>
                <th>City</th>
                <th>Postcode</th>
                <th>Category</th>
                <th>Description</th>
                <th>Info</th>
                <th>Contact</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in LostItems)
            {
                <tr>
                    <th>
                        <NavLink href="@($"/lostitems/{item.Id}")">
                            @item.ItemDescription
                        </NavLink>
                    </th>


                    <td>@item.City</td>

                    <td>@item.Postcode</td>

                    <td>@item.Category</td>

                    <td>@item.AdditionalInformation</td>

                    <td>
                        <figure class="image is-64x64">
                            <img src="images/reunitedlogo.png" />
                        </figure>
                    </td>

                    <td>
                        <div>
                            <strong>@item.Email</strong><br />
                            @item.PhoneNumber
                        </div>
                    </td>
                </tr>
            }
        </tbody>

    </table>
</div>

@if (showDeleteModal)
{
    <div class="modal is-active">

        <div class="modal-background" @onclick="CloseModal"></div>

        <div class="modal-card">

            <header class="modal-card-head">
                <p class="modal-card-title">Confirm Delete</p>
                <button class="delete" aria-label="close" @onclick="CloseModal"></button>
            </header>

            <section class="modal-card-body">
                <p>Are you sure you want to delete:</p>

                <strong>@selectedItem?.ItemDescription</strong>
                <p>@selectedItem?.City</p>
            </section>

            <footer class="modal-card-foot">
                <button class="button is-danger" @onclick="DeleteItem">
                    Delete
                </button>

                <button class="button" @onclick="CloseModal">
                    Cancel
                </button>
            </footer>

        </div>

    </div>
}

@code {
    [Parameter]
    public List<LostItem> LostItems { get; set; } = new();

    private bool showDeleteModal = false;
    private LostItem? selectedItem;

    private void OpenDeleteModal(LostItem item)
    {
        selectedItem = item;
        showDeleteModal = true;
    }

    private void CloseModal()
    {
        selectedItem = null;
        showDeleteModal = false;
    }

    private async Task DeleteItem()
    {
        if (selectedItem == null)
            return;

        await Http.DeleteAsync(
            $"http://localhost:5265/api/lostitems/{selectedItem.Id}"
        );

        LostItems.Remove(selectedItem);

        CloseModal();
    }
}

