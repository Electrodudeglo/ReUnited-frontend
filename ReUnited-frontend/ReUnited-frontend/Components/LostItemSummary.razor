@using ReUnited_frontend.DataModels

<div class="lost-item-page">

    <div class="lost-item-card">

		<img src="uploads/e131b03b-222e-4992-a315-2d45f4324622.jpg"
             alt="Lost item image"
             class="lost-item-image" />

        <h3 class="title is-5 has-text-centered" style="color: #eee;">
            @LostItem.ItemDescription
        </h3>

        <div class="found-box">
            <p class="has-text-weight-semibold">Found at</p>
            <p>@LostItem.City @LostItem.Postcode</p>
        </div>

        <div class="map-preview">
            <img src="https://placehold.co/100x100?text=Map"
                 class="map-image"
                 alt="Map preview" />
        </div>

        <div class="details-grid">
            <p><strong>Email:</strong> @LostItem.Email</p>
            <p><strong>Phone:</strong> @LostItem.PhoneNumber</p>
            <p><strong>Category:</strong> @LostItem.Category</p>
            <p class="mb-5"><strong>Notes:</strong> @LostItem.AdditionalInformation</p>
        </div>

        <footer class="card-footer">
            <NavLink class="card-footer-item button mr-5"
                     href="@($"/lostitems/edit/{LostItem.Id}")">
                Edit
            </NavLink>

            <a class="card-footer-item button is-danger">
                Delete
            </a>
        </footer>

    </div>

</div>



@code {
    [Parameter]
    public LostItem LostItem { get; set; }
}
