@using ReUnited_frontend.Components.UI
@using ReUnited_frontend.DataModels
@using System.Text.Json.Serialization


@if (_summaryLoader != null)
{
	<div>
		<FoundItemsSummaryList 
			FoundItems="_summaryLoader"/>
	</div>
	
}

else {

<div>
	<h3>Cannot load albums</h3>
	<p>@errorMessage</p>
</div>
}

@code {
	@rendermode InteractiveServer
	private List<FoundItem> _summaryLoader { get; set; } = new();

	private string errorMessage = "";

	private bool showDeleteModal = true;

	private FoundItem? selectedItem;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			var http = new HttpClient();
			var response = await http.GetFromJsonAsync<List<FoundItem>>($"http://localhost:5265/api/founditems");

		if (response != null)
		{
			_summaryLoader = response;
		}

		}

		catch (Exception ex)
		{
			errorMessage = $"An error occurred: {ex.Message}";
		}
	}
	private async Task OpenDeleteModal(FoundItem item)
	{
		selectedItem = item;
		showDeleteModal = true;
		await InvokeAsync(StateHasChanged);
	}

	private void CloseDeleteModal()
	{
		selectedItem = null;
		showDeleteModal = false;
	}

	private async Task DeleteItem(FoundItem item)
	{
        Console.WriteLine($"Attempting to delete item with ID: {item.Id}");
		try
		{
			var http = new HttpClient(); 
			var response = await http.DeleteAsync(
				$"http://localhost:5265/api/founditems/{item.Id}"
			);

			_summaryLoader = _summaryLoader
			.Where(x => x.Id != item.Id)
			.ToList();
	                    
			CloseDeleteModal();
		}
		catch (Exception ex)
		{
			errorMessage = $"Delete failed: {ex.Message}";
		}
	}
}


