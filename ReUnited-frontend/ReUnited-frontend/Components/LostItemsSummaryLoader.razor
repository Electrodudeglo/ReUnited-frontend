@using ReUnited_frontend.DataModels
@using System.Text.Json.Serialization


@if (_summaryLoader != null)
{
	<div>
		<LostItemsSummaryList 
			LostItems="_summaryLoader"
			OnDeleteRequested="OpenDeleteModal" />
	</div>
	<LostItemDeleteComponent 
		Item="selectedItem"
							 
		Show="showDeleteModal"
							 
		OnClose="CloseDeleteModal"
							 
		OnDeleteConfirmed="DeleteItem" />
}

else {

<div>
	<h3>Cannot load albums</h3>
	<p>@errorMessage</p>
</div>
}

@code {

	private List<LostItem> _summaryLoader { get; set; } = new();

	private string errorMessage = "";

	private bool showDeleteModal = false;

	private LostItem? selectedItem;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			var http = new HttpClient();
			var response = await http.GetFromJsonAsync<List<LostItem>>($"http://localhost:5265/api/lostitems");

		if (response != null)
		{
			_summaryLoader = response;
		}

		}

		catch (Exception ex)
		{
			errorMessage = $"An error occurred: {ex.Message}";
		}
	}
	private void OpenDeleteModal(LostItem item)
	{
		selectedItem = item;
		showDeleteModal = true;
	}

	private void CloseDeleteModal()
	{
		selectedItem = null;
		showDeleteModal = false;
	}

	private async Task DeleteItem(LostItem item)
	{
		try
		{
			var http = new HttpClient();

			await http.DeleteAsync(
				$"http://localhost:5265/api/lostitems/{item.Id}"
			);

			_summaryLoader.Remove(item);

			CloseDeleteModal();
		}
		catch (Exception ex)
		{
			errorMessage = $"Delete failed: {ex.Message}";
		}
	}
}


