@using Microsoft.AspNetCore.Components.Forms
@using ReUnited_frontend.DataModels

<h3>PictureUploadComponent</h3>

<div class="field">
    <label class="label">Picture</label>

    <div class="file has-name is-boxed">
        <label class="file-label">
            <InputFile class="file-input"
                       OnChange="HandleFileSelected" />

            <span class="file-cta">
                <span class="file-icon">
                    <i class="fas fa-upload"></i>
                </span>
                <span class="file-label">
                    Choose a file...
                </span>
            </span>

            <span class="file-name">
                @(string.IsNullOrWhiteSpace(LostItem.Picture)
                                ? "No file selected"
                                : LostItem.Picture)
            </span>
        </label>
    </div>

    <ValidationMessage For="@(() => LostItem.Picture)" />
</div>
@code {
    [Parameter]
    public LostItem LostItem { get; set; } = new();

    private IBrowserFile? selectedFile;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;

        // Store filename in the model
        LostItem.Picture = selectedFile.Name;
    }
}
